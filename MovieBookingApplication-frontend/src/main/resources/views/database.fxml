<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="500.0" prefWidth="600.0" style="-fx-background-color: #f5f5f5;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.maia.controllers.DatabaseController">

    <fx:include source="menu.fxml" />

    <VBox alignment="CENTER" spacing="25.0" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="20.0" />
        </padding>

        <Label text="Database Management" style="-fx-font-weight: bold; -fx-text-fill: #333333;">
            <font>
                <Font size="24.0" />
            </font>
        </Label>

        <VBox spacing="20.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">

            <VBox spacing="10.0" alignment="CENTER_LEFT">
                <Label text="Create a Database Save" style="-fx-font-weight: bold; -fx-text-fill: #555555;">
                    <font><Font size="14.0" /></font>
                </Label>
                <Button mnemonicParsing="false" onAction="#handleBackupAction" prefHeight="35.0" prefWidth="200.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="TRIGGER BACKUP" />
            </VBox>

            <HBox style="-fx-background-color: #e0e0e0; -fx-min-height: 1; -fx-max-height: 1;" />

            <VBox spacing="10.0" alignment="CENTER_LEFT">
                <Label text="Restore Database from File" style="-fx-font-weight: bold; -fx-text-fill: #555555;">
                    <font><Font size="14.0" /></font>
                </Label>
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <ComboBox fx:id="backupComboBox" prefHeight="35.0" prefWidth="250.0" promptText="Select a backup file..." style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-radius: 5;" />
                    <Button mnemonicParsing="false" onAction="#handleRestoreAction" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="RESTORE DATABASE" />
                </HBox>
            </VBox>

        </VBox>
    </VBox>
</VBox>