<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="650.0" prefWidth="900.0" spacing="15.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.maia.controllers.GetAllMoviesController">
    <children>
        <fx:include source="menu.fxml" />

        <VBox alignment="CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
            </padding>

            <Label text="Get All Movies">
                <font>
                    <Font name="System Bold" size="20.0" />
                </font>
            </Label>

            <Label fx:id="welcomeText" text="Click refresh to load data" textFill="#666666" />

            <Button onAction="#onHelloButtonClick" prefHeight="30.0" prefWidth="180.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="refresh" />

            <TableView fx:id="movieTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" prefWidth="50.0" text="ID" />
                    <TableColumn fx:id="nameColumn" prefWidth="150.0" text="Title" />
                    <TableColumn fx:id="descriptionColumn" prefWidth="250.0" text="Description" />
                    <TableColumn fx:id="genreColumn" prefWidth="100.0" text="Genre" />
                    <TableColumn fx:id="durationColumn" prefWidth="80.0" text="Duration (h)" />
                    <TableColumn fx:id="releaseDateColumn" prefWidth="120.0" text="Release Date" />
                    <TableColumn fx:id="languageColumn" prefWidth="100.0" text="Language" />
                </columns>
                <VBox.margin>
                    <Insets top="10.0" />
                </VBox.margin>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
    </children>
</VBox>